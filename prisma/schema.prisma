generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectType {
  ECOMMERCE
  B2B_CATALOG
  CONTENT
  SAAS
  MARKETPLACE
  CUSTOM
}

enum Capability {
  COMMERCE
  MARKETPLACE
  CRM
  FINANCE
  CONTENT
  ANALYTICS
  AI
}

enum IntegrationType {
  API
  WEBHOOK
  CMS
  MANUAL
}

enum OrderSource {
  WHATSAPP
  MANUAL
  WEB_CHECKOUT
  API
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum PaymentMethod {
  UPI
  COD
  RAZORPAY
  STRIPE
  BANK_TRANSFER
}

enum LeadSource {
  WEBSITE_FORM
  WHATSAPP
  CALENDLY
  MANUAL
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum ConversationStatus {
  ACTIVE
  RESOLVED
  ARCHIVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum UserRole {
  SUPER_ADMIN
  PROJECT_ADMIN
  FINANCE_MANAGER
  SUPPORT_AGENT
  VENDOR_USER
  CLIENT_VIEWER
  CONTENT_EDITOR
}

enum ProjectRole {
  ADMIN
  EDITOR
  VIEWER
}

enum VendorCategory {
  HOTEL
  CAB
  RESTAURANT
  TOUR_GUIDE
  EXPERIENCE
}

enum VendorStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum EnquiryType {
  HOTEL
  CAB
  PACKAGE
  RESTAURANT
  CONTACT
  AI_PLAN
}

enum EnquiryStatus {
  NEW
  ASSIGNED
  IN_DISCUSSION
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum ListingType {
  HOTEL
  CAB
  RESTAURANT
  TOUR_GUIDE
  EXPERIENCE
  PACKAGE
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum EscrowStatus {
  HELD
  RELEASED
  PARTIALLY_RELEASED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  PROCESSED
  REJECTED
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  HOLD
  RELEASE
  REFUND
  COMMISSION
  PAYOUT
}

model Project {
  id              String          @id @default(uuid())
  name            String
  slug            String          @unique
  type            ProjectType     @default(CUSTOM)
  capabilities    Capability[]
  domain          String?
  logoUrl         String?
  integrationType IntegrationType @default(MANUAL)
  config          Json?
  isActive        Boolean         @default(true)
  apiKey          String          @unique @default(uuid())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  vendors             Vendor[]
  enquiries           Enquiry[]
  listings            Listing[]
  promotions          Promotion[]
  destinations        Destination[]
  orders              Order[]
  commissions         Commission[]
  escrows             Escrow[]
  payouts             Payout[]
  refunds             Refund[]
  vendorWallets       VendorWallet[]
  vendorBankAccounts  VendorBankAccount[]
  walletTransactions  WalletTransaction[]
  customers           Customer[]
  products            Product[]
  leads               Lead[]
  invoices            Invoice[]
  expenses            Expense[]
  clientAccess        ClientAccess[]
  contentEntries      ContentEntry[]
  analyticsEvents     AnalyticsEvent[]
  whatsappConversations WhatsAppConversation[]
  users               UserProject[]
}

model Vendor {
  id              String         @id @default(uuid())
  projectId       String
  businessName    String
  ownerName       String
  category        VendorCategory
  phone           String
  email           String?
  gst             String?
  district        String
  address         String?
  status          VendorStatus   @default(PENDING)
  documents       Json?          @default("[]")
  responseRate    Int?           @default(0)
  avgResponseTime String?
  rejectionReason String?
  suspensionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  enquiries Enquiry[]
  listings  Listing[]
  orders    Order[]
  commissions Commission[]
  bankAccount VendorBankAccount?
  wallet VendorWallet?
  payouts Payout[]
  walletTransactions WalletTransaction[]
  project   Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, businessName])
  @@index([projectId, status])
}

model Listing {
  id          String        @id @default(uuid())
  projectId   String
  vendorId    String?
  type        ListingType
  name        String
  description String?
  images      Json?         @default("[]")
  pricing     Json?         @default("[]")
  location    Json?         @default("{}")
  amenities   String[]      @default([])
  tags        String[]      @default([])
  status      ListingStatus @default(DRAFT)
  rating      Float?        @default(0)
  reviewCount Int?          @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  vendor  Vendor?  @relation(fields: [vendorId], references: [id])

  @@index([projectId, status])
  @@index([projectId, vendorId])
}

model Promotion {
  id              String       @id @default(uuid())
  projectId       String
  code            String
  type            DiscountType
  value           Int
  minCartValue    Int?         @default(0)
  maxDiscount     Int?         @default(0)
  applicableTypes String[]     @default([])
  usageLimit      Int?         @default(0)
  perUserLimit    Int?         @default(1)
  usedCount       Int          @default(0)
  validFrom       DateTime?
  validTo         DateTime?
  isActive        Boolean      @default(true)
  description     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, code])
  @@index([projectId, isActive])
}

model Destination {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  slug        String?
  description String?
  district    String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, name])
  @@index([projectId, isActive])
}

model Enquiry {
  id             String         @id @default(uuid())
  projectId      String
  type           EnquiryType
  customerName   String
  customerPhone  String
  customerEmail  String?
  customerCity   String?
  listingName    String?
  vendorId       String?
  details        Json?          @default("{}")
  status         EnquiryStatus  @default(NEW)
  assignedTo     String?
  priority       String?        @default("medium")
  source         String?
  language       String?        @default("English")
  messages       Json?          @default("[]")
  notes          Json?          @default("[]")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  vendor  Vendor?  @relation(fields: [vendorId], references: [id])

  @@index([projectId, status])
  @@index([projectId, vendorId])
}

model Customer {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  phone       String?
  email       String?
  address     Json?
  tags        String[] @default([])
  notes       String?
  totalOrders Int      @default(0)
  totalSpent  Decimal  @default(0) @db.Decimal(10, 2)
  lastOrderAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project               Project                   @relation(fields: [projectId], references: [id])
  orders                Order[]
  leads                 Lead[]
  whatsappConversations WhatsAppConversation[]

  @@unique([projectId, phone])
  @@unique([projectId, email])
}

model Order {
  id                 String        @id @default(uuid())
  orderNumber        String
  projectId          String
  vendorId           String?
  customerId         String?
  source             OrderSource   @default(MANUAL)
  status             OrderStatus   @default(PENDING)
  paymentStatus      PaymentStatus @default(UNPAID)
  paymentMethod      PaymentMethod?
  paymentProvider    String?
  paymentProviderId  String?
  totalAmount        Decimal       @db.Decimal(10, 2)
  discount           Decimal       @default(0) @db.Decimal(10, 2)
  commissionAmount   Decimal       @default(0) @db.Decimal(10, 2)
  platformFee        Decimal       @default(0) @db.Decimal(10, 2)
  gstAmount          Decimal       @default(0) @db.Decimal(10, 2)
  checkIn            DateTime?
  checkOut           DateTime?
  guests             Int?
  roomType           String?
  pickupLocation     String?
  dropoffLocation    String?
  notes              String?
  assignedTo         String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  project  Project        @relation(fields: [projectId], references: [id])
  vendor   Vendor?        @relation(fields: [vendorId], references: [id])
  customer Customer?      @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  timeline OrderTimeline[]
  invoices Invoice[]
  escrow   Escrow?
  refunds  Refund[]

  @@index([projectId, createdAt])
  @@index([projectId, vendorId])
  @@index([customerId])
  @@index([status])
}

model Commission {
  id            String         @id @default(uuid())
  projectId     String
  vendorId      String?
  category      VendorCategory?
  rate          Decimal        @db.Decimal(5, 2)
  minAmount     Decimal        @default(0) @db.Decimal(10, 2)
  maxAmount     Decimal?       @db.Decimal(10, 2)
  isActive      Boolean        @default(true)
  effectiveFrom DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  vendor  Vendor? @relation(fields: [vendorId], references: [id])

  @@index([projectId, category])
  @@index([projectId, vendorId])
}

model Escrow {
  id             String       @id @default(uuid())
  projectId      String
  orderId        String       @unique
  grossAmount    Decimal      @db.Decimal(10, 2)
  commissionAmount Decimal    @default(0) @db.Decimal(10, 2)
  vendorAmount   Decimal      @db.Decimal(10, 2)
  gstAmount      Decimal      @default(0) @db.Decimal(10, 2)
  status         EscrowStatus @default(HELD)
  heldAt         DateTime     @default(now())
  releaseDueAt   DateTime?
  releasedAt     DateTime?
  refundedAt     DateTime?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([projectId, releaseDueAt])
}

model VendorBankAccount {
  id            String   @id @default(uuid())
  projectId     String
  vendorId      String   @unique
  accountHolder String
  bankName      String?
  accountNumber String?
  ifscCode      String?
  upiId         String?
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model VendorWallet {
  id             String   @id @default(uuid())
  projectId      String
  vendorId       String   @unique
  balance        Decimal  @default(0) @db.Decimal(10, 2)
  pendingBalance Decimal  @default(0) @db.Decimal(10, 2)
  totalEarned    Decimal  @default(0) @db.Decimal(10, 2)
  totalWithdrawn Decimal  @default(0) @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([projectId])
}

model WalletTransaction {
  id          String                @id @default(uuid())
  projectId   String
  walletId    String
  vendorId    String
  type        WalletTransactionType
  amount      Decimal               @db.Decimal(10, 2)
  referenceId String?
  description String?
  createdAt   DateTime              @default(now())

  project Project @relation(fields: [projectId], references: [id])
  wallet  VendorWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  vendor  Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([walletId, createdAt])
}

model Payout {
  id          String       @id @default(uuid())
  projectId   String
  vendorId    String
  amount      Decimal      @db.Decimal(10, 2)
  status      PayoutStatus @default(PENDING)
  scheduledFor DateTime?
  processedAt DateTime?
  utrNumber   String?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([projectId, scheduledFor])
  @@index([vendorId])
}

model Refund {
  id          String       @id @default(uuid())
  projectId   String
  orderId     String
  amount      Decimal      @db.Decimal(10, 2)
  reason      String?
  status      RefundStatus @default(REQUESTED)
  requestedAt DateTime     @default(now())
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([orderId])
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  productId   String?
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  lineTotal   Decimal @db.Decimal(10, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model OrderTimeline {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  note      String?
  userId    String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Product {
  id                String   @id @default(uuid())
  projectId         String
  externalId        String?
  name              String
  sku               String?
  category          String?
  price             Decimal  @db.Decimal(10, 2)
  cost              Decimal? @db.Decimal(10, 2)
  stock             Int?
  lowStockThreshold Int?     @default(5)
  isActive          Boolean  @default(true)
  imageUrl          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project        Project          @relation(fields: [projectId], references: [id])
  orderItems     OrderItem[]
  stockMovements StockMovement[]
}

model StockMovement {
  id          String             @id @default(uuid())
  productId   String
  type        StockMovementType
  quantity    Int
  reason      String?
  referenceId String?
  createdAt   DateTime           @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model Lead {
  id           String     @id @default(uuid())
  projectId    String
  customerId   String?
  name         String
  email        String?
  company      String?
  phone        String?
  source       LeadSource @default(WEBSITE_FORM)
  status       LeadStatus @default(NEW)
  score        Int?
  scoreReason  String?
  products     String[]   @default([])
  quantity     String?
  message      String?
  assignedTo   String?
  nextFollowUp DateTime?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  project  Project   @relation(fields: [projectId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([projectId, status])
}

model WhatsAppConversation {
  id            String             @id @default(uuid())
  projectId     String
  customerId    String?
  waContactId   String
  status        ConversationStatus @default(ACTIVE)
  unreadCount   Int                @default(0)
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())

  project  Project           @relation(fields: [projectId], references: [id])
  customer Customer?         @relation(fields: [customerId], references: [id])
  messages WhatsAppMessage[]

  @@index([projectId, lastMessageAt])
}

model WhatsAppMessage {
  id             String           @id @default(uuid())
  conversationId String
  direction      MessageDirection
  content        String
  messageType    String           @default("text")
  waMessageId    String?
  metadata       Json?
  createdAt      DateTime         @default(now())

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String        @id @default(uuid())
  orderId       String?
  order         Order?        @relation(fields: [orderId], references: [id])
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id])
  invoiceNumber String        @unique
  amount        Decimal       @db.Decimal(10, 2)
  taxAmount     Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal       @db.Decimal(10, 2)
  status        String        @default("DRAFT")
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items InvoiceItem[]

  @@index([projectId])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
}

model Expense {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  description String
  amount      Decimal  @db.Decimal(10, 2)
  category    String
  date        DateTime
  receipt     String?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([projectId, date])
}

model ClientAccess {
  id           String    @id @default(uuid())
  projectId    String
  name         String
  email        String
  phone        String?
  sharedSecret String
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, email])
  @@index([projectId])
}

model ContentEntry {
  id          String   @id @default(uuid())
  projectId   String
  externalId  String?
  title       String
  slug        String?
  body        String?
  type        String   @default("page")
  status      String   @default("draft")
  updatedBy   String?
  lastSyncedAt DateTime?
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model AnalyticsEvent {
  id         String   @id @default(uuid())
  projectId  String
  event      String
  properties Json?
  sessionId  String?
  userId     String?
  ip         String?
  userAgent  String?
  pageUrl    String?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, event, createdAt])
  @@index([sessionId])
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(SUPER_ADMIN)
  preferences   Json?
  createdAt     DateTime  @default(now())

  projects UserProject[]
  accounts Account[]
  sessions Session[]
}

model UserProject {
  userId    String
  projectId String
  role      ProjectRole @default(ADMIN)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@unique([identifier, token])
}
